{% style %}
  .footer-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    position: relative;
    {% if section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }

  {% if section.settings.background_overlay and section.settings.background_image != blank %}
    .footer-section-{{ section.id }}::before {
      content: '';
      position: absolute;
      inset: 0;
      background-color: {{ section.settings.overlay_color }};
      opacity: 0.85;
      z-index: 0;
    }
    .footer-section-{{ section.id }} > * {
      position: relative;
      z-index: 1;
    }
  {% endif %}

  @media screen and (min-width: 750px) {
    .footer-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .social-icons-{{ section.id }} {
    display: flex;
    flex-direction: {% if section.settings.social_icon_direction == 'vertical' %}column{% else %}row{% endif %};
    gap: {{ section.settings.social_icon_gap | default: 12 }}px;
    align-items: center;
    justify-content: center;
  }

  .social-icons-{{ section.id }} a {
    width: {{ section.settings.social_icon_size | default: 40 }}px;
    height: {{ section.settings.social_icon_size | default: 40 }}px;
    color: {{ section.settings.social_icon_color | default: '#ffffff' }};
    border-color: currentColor;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .social-icons-{{ section.id }} a:hover {
    color: {{ section.settings.social_icon_hover_color | default: '#C8815F' }};
  }

  .social-icons-{{ section.id }} a svg {
    width: 50%;
    height: 50%;
  }
{% endstyle %}

<footer class="footer-section-{{ section.id }}">
  <div class="container mx-auto px-4 md:px-6 lg:px-8">
    
    {%- assign newsletter_block = section.blocks | where: 'type', 'newsletter' | first -%}
    {% if newsletter_block %}
      <div class="footer-section-speaking max-w-[75%] mx-auto flex flex-col md:flex-row justify-between items-center gap-8" {{ newsletter_block.shopify_attributes }}>
        <div class="md:w-1/2">
          {% if newsletter_block.settings.heading != blank %}
            <h2 class="text-2xl lg:text-3xl  font-bold mb-3 tracking-wide">{{ newsletter_block.settings.heading }}</h2>
          {% endif %}
          {% if newsletter_block.settings.subtext != blank %}
            <div class="text-base text-white leading-relaxed max-w-xl">
              {{ newsletter_block.settings.subtext }}
            </div>
          {% endif %}
        </div>
        <div class="md:w-1/2 w-full">
          {% form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form w-full' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="flex items-stretch w-full max-w-lg ml-auto">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="w-full px-4 py-3 text-sm placeholder:text-white! text-white bg-white/3! border border-white/30! focus:border-[#C89B6A]! focus:outline-none transition-colors"
                style="outline: none !important; box-shadow: none !important;"
                value="{{ form.email }}"
                aria-required="true"
                placeholder="Enter your email address"
                required
              >
              <button type="submit" class="bg-[#C89B6A] text-white px-8 py-3 text-sm font-medium hover:bg-opacity-90 transition-colors whitespace-nowrap cursor-pointer" name="commit" aria-label="Subscribe">
                Subscribe
              </button>
            </div>
            {%- if form.errors -%}
              <small class="text-red-500 block mt-2 text-right" id="ContactFooter-error">
                <svg class="w-4 h-4 inline mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}
              </small>
            {%- endif -%}
            {%- if form.posted_successfully? -%}
              <h3 class="text-green-500 block mt-2 text-sm text-right" id="ContactFooter-success" tabindex="-1" autofocus>
                <svg class="w-4 h-4 inline mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                Thanks for subscribing!
              </h3>
            {%- endif -%}
          {% endform %}
        </div>
      </div>
    {% endif %}

    <div class="flex flex-wrap lg:flex-nowrap justify-between gap-8 mb-12 lg:pt-16 pt-6">
      {%- assign other_block_count = 0 -%}
      {% for block in section.blocks %}
        {% if block.type != 'about' and block.type != 'newsletter' %}
          {%- assign other_block_count = other_block_count | plus: 1 -%}
        {% endif %}
      {% endfor %}
      
      {%- assign mid_point = other_block_count | divided_by: 2.0 | ceil -%}
      {%- assign current_other_count = 0 -%}

      {% for block in section.blocks %}
        {% if block.type == 'newsletter' %}{% continue %}{% endif %}
        
        {% case block.type %}
          {% when 'about' %}
            <div class="footer-block lg:w-[30%] flex flex-col items-center text-center order-1 lg:order-2" {{ block.shopify_attributes }}>
              {% if block.settings.logo != blank %}
                <a href="{{ routes.root_url }}" class="inline-block mb-6">
                  <img src="{{ block.settings.logo | image_url: width: 300 }}" 
                       alt="{{ block.settings.logo.alt | default: shop.name }}" 
                       style="max-width: {{ block.settings.logo_width }}px"
                       loading="lazy">
                </a>
              {% else %}
                <h2 class="text-2xl font-bold mb-4 tracking-wide flex items-center justify-center gap-2">
                  <svg class="w-6 h-6 text-[#C89B6A]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {{ shop.name }}
                </h2>
              {% endif %}
              
              {% if block.settings.description != blank %}
                <div class="text-base text-white opacity-80 leading-relaxed mb-6 max-w-sm">
                  {{ block.settings.description }}
                </div>
              {% endif %}

              
              {% if block.settings.show_social %}
                <div class="social-icons-{{ section.id }} mt-0">
                      <a href="{{ section.settings.social_facebook_link | default: '#' }}" class="social-icon-item rounded-full border border-current border-opacity-30 hover:border-opacity-100 transition-all">
                          <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
                      </a>
                      <a href="{{ section.settings.social_twitter_link | default: '#' }}" class="social-icon-item rounded-full border border-current border-opacity-30 opacity-80 hover:opacity-100 hover:border-opacity-100 transition-all">
                          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" /></svg>
                      </a>
                      <a href="{{ section.settings.social_instagram_link | default: '#' }}" class="social-icon-item rounded-full border border-current border-opacity-30 opacity-80 hover:opacity-100 hover:border-opacity-100 transition-all">
                          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg>
                      </a>
                  </div>
              {% endif %}
            </div>

          {% when 'link_list' %}
            {%- assign current_other_count = current_other_count | plus: 1 -%}
            {%- if current_other_count <= mid_point -%}
               {%- assign order_class = 'order-none lg:order-1' -%}
            {%- else -%}
               {%- assign order_class = 'order-none lg:order-3' -%}
            {%- endif -%}
            <div class="footer-block w-[45%] lg:flex-1 {{ order_class }}" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h3 class="text-2xl font-bold text-white mb-6 tracking-wide">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.menu != blank %}
                <ul class="space-y-4">
                  {% for link in block.settings.menu.links %}
                    <li>
                      <a href="{{ link.url }}" class="text-base text-white/80 hover:text-[#C89B6A] transition-all duration-300! inline-block">
                        {{ link.title }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>

          {% when 'contact_info' %}
            {%- assign current_other_count = current_other_count | plus: 1 -%}
            {%- if current_other_count <= mid_point -%}
               {%- assign order_class = 'order-none lg:order-1' -%}
            {%- else -%}
               {%- assign order_class = 'order-none lg:order-3' -%}
            {%- endif -%}
            <div class="footer-block w-[45%] lg:flex-1 {{ order_class }}" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h3 class="text-2xl font-bold text-white mb-6 tracking-wide">{{ block.settings.heading }}</h3>
              {% endif %}
              <ul class="space-y-4 text-base text-white/80">
                {% if block.settings.address != blank %}
                  <li class="flex items-start">
                    <svg class="w-5 h-5 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    <span>{{ block.settings.address }}</span>
                  </li>
                {% endif %}
                {% if block.settings.phone != blank %}
                  <li class="flex items-center">
                    <svg class="w-5 h-5 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    <a href="tel:{{ block.settings.phone }}" class="hover:text-[#C89B6A] transition-colors">{{ block.settings.phone }}</a>
                  </li>
                {% endif %}
                {% if block.settings.email != blank %}
                  <li class="flex items-center">
                    <svg class="w-5 h-5 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    <a href="mailto:{{ block.settings.email }}" class="hover:text-[#C89B6A] transition-colors">{{ block.settings.email }}</a>
                  </li>
                {% endif %}
              </ul>
            </div>
        {% endcase %}
      {% endfor %}
    </div>

    <div class="mt-12 border-t pt-7.5 border-white/10 flex justify-center items-center">
      <div class="text-sm opacity-80 text-center">
        Copyright &copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. {{ section.settings.copyright_text }}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
    "type": "header",
    "content": "Layout"
  },
  {
    "type": "select",
    "id": "direction",
    "label": "Direction",
    "options": [
      { "value": "vertical", "label": "Vertical" },
      { "value": "horizontal", "label": "Horizontal" }
    ],
    "default": "vertical"
  },
  {
    "type": "checkbox",
    "id": "vertical_mobile",
    "label": "Vertical on mobile",
    "default": false
  },
  {
    "type": "select",
    "id": "alignment",
    "label": "Alignment",
    "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" },
      { "value": "right", "label": "Right" }
    ],
    "default": "left"
  },
  {
    "type": "range",
    "id": "gap",
    "label": "Gap",
    "min": 0,
    "max": 200,
    "step": 4,
    "unit": "px",
    "default": 100
  },

  {
    "type": "header",
    "content": "Size"
  },
  {
    "type": "select",
    "id": "width",
    "label": "Width",
    "options": [
      { "value": "page", "label": "Page" },
      { "value": "full", "label": "Full" }
    ],
    "default": "page"
  },
  {
    "type": "select",
    "id": "height",
    "label": "Height",
    "options": [
      { "value": "auto", "label": "Auto" },
      { "value": "small", "label": "Small" },
      { "value": "medium", "label": "Medium" },
      { "value": "large", "label": "Large" }
    ],
    "default": "auto"
  },

  {
    "type": "header",
    "content": "Appearance"
  },
  {
    "type": "image_picker",
    "id": "background_image",
    "label": "Background image"
  },
  {
    "type": "color",
    "id": "background_color",
    "label": "Background color",
    "default": "#172430"
  },
  {
    "type": "header",
    "content": "Social Media Links"
  },
  {
    "type": "url",
    "id": "social_facebook_link",
    "label": "Facebook URL"
  },
  {
    "type": "url",
    "id": "social_twitter_link",
    "label": "Twitter URL"
  },
  {
    "type": "url",
    "id": "social_instagram_link",
    "label": "Instagram URL"
  },
  {
    "type": "color",
    "id": "social_icon_color",
    "label": "Social icon color",
    "default": "#ffffff"
  },
  {
    "type": "color",
    "id": "social_icon_hover_color",
    "label": "Social icon hover color",
    "default": "#C8815F"
  },
  {
    "type": "range",
    "id": "social_icon_size",
    "label": "Social icon size",
    "min": 28,
    "max": 80,
    "step": 2,
    "unit": "px",
    "default": 40
  },
  {
    "type": "range",
    "id": "social_icon_gap",
    "label": "Social icon gap",
    "min": 4,
    "max": 40,
    "step": 2,
    "unit": "px",
    "default": 12
  },
  {
    "type": "select",
    "id": "social_icon_direction",
    "label": "Icon direction",
    "options": [
      { "value": "horizontal", "label": "Horizontal" },
      { "value": "vertical", "label": "Vertical" }
    ],
    "default": "horizontal"
  },
  {
    "type": "color",
    "id": "text_color",
    "label": "Text color",
    "default": "#ffffff"
  },
  {
    "type": "color",
    "id": "sub_text_color",
    "label": "Sub Text color",
    "default": "#ffffff"
  },
  {
    "type": "checkbox",
    "id": "background_overlay",
    "label": "Background overlay",
    "default": false
  },
  {
    "type": "color",
    "id": "overlay_color",
    "label": "Overlay color",
    "default": "#000000"
  },

  {
    "type": "header",
    "content": "Borders"
  },
  {
    "type": "range",
    "id": "border_radius",
    "label": "Corner radius",
    "min": 0,
    "max": 50,
    "step": 1,
    "unit": "px",
    "default": 0
  },

  {
    "type": "header",
    "content": "Padding"
  },
  {
    "type": "range",
    "id": "padding_top",
    "label": "Top",
    "min": 0,
    "max": 200,
    "step": 4,
    "unit": "px",
    "default": 48
  },
  {
    "type": "range",
    "id": "padding_bottom",
    "label": "Bottom",
    "min": 0,
    "max": 200,
    "step": 4,
    "unit": "px",
    "default": 48
  }
  ],
  "blocks": [
    {
      "type": "about",
      "name": "About Store",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 50,
          "max": 250,
          "step": 10,
          "default": 150,
          "unit": "px",
          "label": "Logo Width"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Discover the finest furniture to elevate your home. Quality craftsmanship and timeless design.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "Show Social Icons",
          "info": "To edit social media links, use the Social Media Links settings in this section."
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Quick Links",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "contact_info",
      "name": "Contact Information",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Contact Us",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address",
          "default": "123 Furniture St, New York, NY 10001"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone Number",
          "default": "+1 (555) 123-4567"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email Address",
          "default": "[EMAIL_ADDRESS]"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Subscribe to our emails",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p>Get the latest updates on new arrivals and exclusive promotions.</p>",
          "label": "Subtext"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "about"
        },
        {
          "type": "link_list"
        },
        {
          "type": "contact_info"
        },
        {
