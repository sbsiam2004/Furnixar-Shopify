<!-- Featured Products Area Start -->
<section
  class="featured-products-section overflow-hidden"
  id="featured-products-{{ section.id }}"
  style="
    --section-bg: {{ section.settings.background_color }};
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="container-fluid">
    {% render 'section-heading',
      show_section_icon: section.settings.show_icon,
      section_icon: section.settings.section_icon,
      icon_color: section.settings.icon_color,
      section_title: section.settings.section_title,
      section_description: section.settings.section_description,
      section_title_class: 'leading-none mt-4 md:mt-6 text-2xl! md:text-3xl! lg:text-[36px]! font-semibold text-white',
      section_description_class: 'mt-3 text-white/75 text-base'
    %}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 sm:gap-8">
      {% if section.settings.collection != blank %}
        {% assign featured_products = section.settings.collection.products %}
      {% else %}
        {% assign featured_products = collections.all.products %}
      {% endif %}

      {% for product in featured_products limit: section.settings.products_to_show %}
        {% render 'product-card',
          product: product,
          review_count: section.settings.default_review_count
        %}
      {% else %}
        {% for i in (1..section.settings.products_to_show) %}
          {% render 'product-card', product: blank, review_count: section.settings.default_review_count %}
        {% endfor %}
      {% endfor %}
    </div>

    {% render 'button',
      button_text: section.settings.button_text,
      button_url: section.settings.button_url,
      button_class: 'featured-products-btn'
    %}
  </div>
</section>
<!-- Featured Products Area End -->

{% stylesheet %}
  .featured-products-section {
    background-color: var(--section-bg);
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .featured-products-section .featured-products-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    border: 1px solid #fff;
    color: #fff;
    background: transparent;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .featured-products-section .featured-products-btn:hover {
    background: var(--color-primary, #c8815f);
    border-color: var(--color-primary, #c8815f);
    color: #fff;
  }
  .featured-products-section .product-card-title {
  position: relative;
  transition: color 0.4s ease;
}

.featured-products-section .product-card-title::before {
  content: '';
  position: absolute;
  left: 0;
  bottom: -2px;
  width: 100%;
  height: 1px;
  background: currentColor;
  transform: scaleX(0);
  transform-origin: left center;
  transition: transform .3s ease;
}

/* Parent hover */
.featured-products-section .group:hover .product-card-title {
  color: var(--color-primary, #c8815f);
}

.featured-products-section .group:hover .product-card-title::before {
  transform: scaleX(1);
}

  .featured-products-section .product-card-image {
    display: block;
    width: 100%;
    height: 447px !important;
    aspect-ratio: 406 / 447 !important;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .featured-products-section .group:hover .product-card-image {
    transform: scale(1.1);
  }

  .featured-products-section .new-product-icon {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 9999px;
    background-color: #172430;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: width 0.3s ease, padding 0.3s ease, border-radius 0.3s ease;
    flex-shrink: 0;
    border: none;
    cursor: pointer;
    text-decoration: none;
  }

  .featured-products-section form {
    margin: 0;
  }

  .featured-products-section .new-product-icon:hover {
    width: auto;
    padding-left: 1rem;
    padding-right: 1rem;
    border-radius: 40px;
    gap: 0.5rem;
  }

  .featured-products-section .new-product-icon span {
    display: inline-block;
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    white-space: nowrap;
    transition: max-width 0.3s ease, opacity 0.3s ease;
    font-size: 1rem;
    line-height: 1;
  }

  .featured-products-section .new-product-icon:hover span {
    max-width: 12rem;
    opacity: 1;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "featured-products-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show icon",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "section_icon",
      "label": "Section icon"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#BB976D"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Heading",
      "default": "New Products"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "label": "Description",
      "default": "Be the first to experience innovation with our latest arrivals. Stay ahead of the curve and discover what's new in style, technology, and more."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#172430"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "default_review_count",
      "label": "Default review count display",
      "default": "1,230"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "All Products"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
