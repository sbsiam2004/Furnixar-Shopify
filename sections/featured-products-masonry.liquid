<!-- Feature Post Start -->
<div
  class="featured-products-masonry-section overflow-hidden"
  id="featured-products-masonry-{{ section.id }}"
  style="
    --section-bg: {{ section.settings.background_color }};
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="container-fluid">
    {% render 'section-heading',
      show_section_icon: section.settings.show_icon,
      section_icon: section.settings.section_icon,
      icon_color: section.settings.icon_color,
      section_title: section.settings.section_title,
      section_description: section.settings.section_description,
      section_title_class: 'max-w-[530px]! leading-none mt-4 md:mt-6 text-2xl! md:text-3xl! lg:text-[36px]! font-semibold text-white',
      section_description_class: 'mt-3 text-white/75 text-base'
    %}

    {%- liquid
      if section.settings.collection != blank
        assign masonry_products = section.settings.collection.products
      else
        assign masonry_products = collections.all.products
      endif
    -%}

    <div class="max-w-[1720px] mx-auto flex gap-5 sm:gap-8 flex-col lg:flex-row">
      <div class="grid sm:grid-cols-2 gap-5 sm:gap-8 lg:max-w-[766px] w-full">
        {% for product in masonry_products limit: 4 %}
          {% render 'product-card',
            product: product,
            review_count: section.settings.default_review_count,
            card_style: 'masonry_small'
          %}
        {% else %}
          {% for i in (1..4) %}
            {% render 'product-card',
              product: blank,
              review_count: section.settings.default_review_count,
              card_style: 'masonry_small'
            %}
          {% endfor %}
        {% endfor %}
      </div>

      <div class="grid sm:grid-cols-2 gap-5 sm:gap-8 lg:max-w-[925px] w-full">
        {% for product in masonry_products offset: 4 limit: 2 %}
          {% render 'product-card',
            product: product,
            review_count: section.settings.default_review_count,
            card_style: 'masonry_tall'
          %}
        {% else %}
          {% for i in (1..2) %}
            {% render 'product-card',
              product: blank,
              review_count: section.settings.default_review_count,
              card_style: 'masonry_tall'
            %}
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>
<!-- Feature Post End -->

{% stylesheet %}
  .featured-products-masonry-section {
    background-color: var(--section-bg);
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .featured-products-masonry-section .text-underline {
    position: relative;
    display: inline-block;
    text-decoration: none;
    color: #fff;
    transition: color 0.3s ease;
  }

  .featured-products-masonry-section .text-underline::before {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.3s ease;
  }

  .featured-products-masonry-section .group:hover .text-underline {
    color: var(--color-primary, #c8815f);
  }

  .featured-products-masonry-section .group:hover .text-underline::before {
    transform: scaleX(1);
  }

  .featured-products-masonry-section .product-card-image {
    display: block;
    transition: transform 0.3s ease;
  }

  .featured-products-masonry-section form {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Products Masonry",
  "tag": "section",
  "class": "featured-products-masonry-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show icon",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "section_icon",
      "label": "Section icon"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#BB976D"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "label": "Description",
      "default": "Discover our handpicked collection of premium furniture and decor, curated to elevate every corner of your home."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#172430"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "default_review_count",
      "label": "Default review count display",
      "default": "1,230"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Featured Products Masonry"
    }
  ]
}
{% endschema %}
