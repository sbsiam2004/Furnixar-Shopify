<!-- Choose Area Start -->
<div
    class="why-choose-section bg-overlay relative overflow-hidden"
    id="why-choose-{{ section.id }}"
    style="
        --overlay-color: {{ section.settings.overlay_color }};
        --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
        --padding-top: {{ section.settings.padding_top }}px;
        --padding-bottom: {{ section.settings.padding_bottom }}px;
        {% if section.settings.background_image != blank %}
        background-image: url('{{ section.settings.background_image | image_url: width: 2400 }}');
        {% endif %}
    "
    >
    {% if section.settings.shape_image != blank %}
        <img
        class="absolute top-0 right-0 w-[20%] z-0 pointer-events-none"
        src="{{ section.settings.shape_image | image_url: width: 600 }}"
        alt=""
        width="{{ section.settings.shape_image.width }}"
        height="{{ section.settings.shape_image.height }}"
        loading="lazy"
        >
    {% endif %}

    <div class="container-fluid relative z-1">
        <div class="max-w-[1720px] mx-auto">
            <div class="max-w-[1186px] ml-auto">
                {% render 'section-heading',
                show_section_icon: section.settings.show_icon,
                section_icon: section.settings.section_icon,
                icon_color: section.settings.icon_color,
                section_title: section.settings.section_title,
                section_description: section.settings.section_description,
                wrapper_class: 'max-w-[1186px]! ml-auto! text-left!',
                section_title_class: 'max-w-[530px]! leading-none mt-4 md:mt-6 text-2xl! md:text-3xl! lg:text-[36px]! font-semibold text-white',
                section_description_class: 'max-w-[530px]! mt-3 text-white/75 text-base',
                icon_container_class: 'justify-start! ml-0!'
                %}

                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-[30px]">
                    {% for block in section.blocks %}
                        {% if block.type == 'why_choose_card' %}
                        {% render 'why-choose-card',
                            block: block,
                            icon_color: section.settings.icon_color,
                            card_bg_color: section.settings.card_bg_color
                        %}
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Choose Area End -->

{% stylesheet %}
    .why-choose-section {
        position: relative;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        padding-top: var(--padding-top);
        padding-bottom: var(--padding-bottom);
    }

    .why-choose-section.bg-overlay::before {
        content: '';
        position: absolute;
        inset: 0;
        background-color: var(--overlay-color);
        opacity: var(--overlay-opacity);
        z-index: 0;
    }
{% endstylesheet %}

{% schema %}
    {
    "name": "Why Choose Us",
    "tag": "section",
    "class": "why-choose-section-wrapper",
    "settings": [
        {
        "type": "header",
        "content": "Background"
        },
        {
        "type": "image_picker",
        "id": "background_image",
        "label": "Background image"
        },
        {
        "type": "image_picker",
        "id": "shape_image",
        "label": "Decorative shape image"
        },
        {
        "type": "color",
        "id": "overlay_color",
        "label": "Overlay color",
        "default": "#172430"
        },
        {
        "type": "range",
        "id": "overlay_opacity",
        "label": "Overlay opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "default": 80
        },
        {
        "type": "color",
        "id": "card_bg_color",
        "label": "Card background",
        "default": "#172430"
        },
        {
        "type": "header",
        "content": "Section heading"
        },
        {
        "type": "checkbox",
        "id": "show_icon",
        "label": "Show icon",
        "default": true
        },
        {
        "type": "image_picker",
        "id": "section_icon",
        "label": "Section icon"
        },
        {
        "type": "color",
        "id": "icon_color",
        "label": "Icon color",
        "default": "#BB976D"
        },
        {
        "type": "text",
        "id": "section_title",
        "label": "Heading",
        "default": "Why you Choose Us"
        },
        {
        "type": "textarea",
        "id": "section_description",
        "label": "Description",
        "default": "Choose us for unparalleled quality, exceptional service, and a commitment to your satisfaction. Join countless others who rely on us for reliability."
        },
        {
        "type": "header",
        "content": "Spacing"
        },
        {
        "type": "range",
        "id": "padding_top",
        "label": "Padding top",
        "min": 0,
        "max": 120,
        "step": 10,
        "unit": "px",
        "default": 100
        },
        {
        "type": "range",
        "id": "padding_bottom",
        "label": "Padding bottom",
        "min": 0,
        "max": 120,
        "step": 10,
        "unit": "px",
        "default": 100
        }
    ],
    "blocks": [
        {
        "type": "why_choose_card",
        "name": "Feature card",
        "settings": [
            {
            "type": "select",
            "id": "icon",
            "label": "Icon",
            "default": "shipping",
            "options": [
                { "value": "shipping", "label": "Free Shipping" },
                { "value": "return", "label": "Easy Return" },
                { "value": "payment", "label": "Secure Payment" },
                { "value": "support", "label": "Customer Support" }
            ]
            },
            {
            "type": "image_picker",
            "id": "icon_image",
            "label": "Custom icon (optional)"
            },
            {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Free Shipping"
            },
            {
            "type": "textarea",
            "id": "description",
            "label": "Description",
            "default": "Enjoy free shipping on all orders, making your shopping experience even more convenient. Get your favorite products delivered."
            }
        ]
        }
    ],
    "presets": [
        {
        "name": "Why Choose Us",
        "blocks": [
            {
            "type": "why_choose_card",
            "settings": {
                "icon": "shipping",
                "title": "Free Shipping",
                "description": "Enjoy free shipping on all orders, making your shopping experience even more convenient. Get your favorite products delivered."
            }
            },
            {
            "type": "why_choose_card",
            "settings": {
                "icon": "return",
                "title": "Easy to Return",
                "description": "Experience hassle-free returns with our easy-to-use return policy. If you're not satisfied, simply return your product for a quick."
            }
            },
            {
            "type": "why_choose_card",
            "settings": {
                "icon": "payment",
                "title": "Secure Payment",
                "description": "Shop with confidence using our secure payment options, ensuring your personal information stays protected. We prioritize your safety."
            }
            },
            {
            "type": "why_choose_card",
            "settings": {
                "icon": "support",
                "title": "Customer Support",
                "description": "Our dedicated customer support team is here to assist you every step of the way. Reach out to us anytime for prompt, friendly help."
            }
            }
        ]
        }
    ]
    }
{% endschema %}
