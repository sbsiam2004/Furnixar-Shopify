<style>
  /* ===== Header Logo ===== */
  .header-area a img {
    width: auto;
    height: auto;
  }

  /* ===== Main Menu ===== */
  .main-menu { display: none; }
  .main-menu.active { display: block; }
  @media (min-width: 1024px) {
    .main-menu { display: block !important; }
  }
  .main-menu > ul > li { padding: 10px 0; border-bottom: 1px solid rgba(0,0,0,0.08); }
  @media (min-width: 1024px) {
    .main-menu > ul > li { padding: 25px 0; border-bottom: none; }
    .main-menu > ul > li > a { color: #fff !important; }
    .main-menu > ul > li > a:hover { color: #C8815F !important; }
  }
  .main-menu ul li a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    transition: all 0.3s ease;
    padding: 8px 0;
    font-size: 16px;
  }
  @media (min-width: 1024px) {
    .main-menu ul li a {
      justify-content: flex-start;
      padding: 0;
    }
  }
  /* Plus and Minus Icons */
  /* Plus and Minus Icons */
    ..menu-list-toggle-icon .plus-icon,
    .menu-list-toggle-icon .minus-icon {
        transition: all 0.3s ease;
        color: inherit;
        display: inline-block;
    }

    .menu-list-toggle-icon .plus-icon {
        display: inline-block;
    }

    .menu-list-toggle-icon .minus-icon {
        display: none;
    }

    .group:hover > a {
        color: #BB976D;
        transition: all 0.3s ease;
    }

    .group:hover .menu-list-toggle-icon .plus-icon {
        display: none;
    }

    .group:hover .menu-list-toggle-icon .minus-icon {
        display: inline-block;
        color: #BB976D;
    }

  /* ===== Sub Menu ===== */
    .sub-menu { list-style: none; padding-left: 15px; }
    @media (min-width: 1024px) {
        .sub-menu {
            position: absolute;
            z-index: 50;
            top: 100%;
            left: 0;
            min-width: 220px;
            visibility: hidden;
            opacity: 0;
            transition: all 0.3s ease;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }
        .group:hover > .sub-menu {
            visibility: visible;
            opacity: 1;
        }
    }
    .sub-menu li a {
        font-size: 18px;
        color: #ffffff;
        padding: 15px 0px !important;
        display: block;
        transition: all 0.3s ease;
        border-bottom: 1px solid #ffffff10;
    }
    .sub-menu li a:hover {
        color: #C8815F;
        padding-left: 20px;
    }
    

    /* ===== Mega Menu ===== */
    .mega-menu { padding-left: 15px; }
    @media (min-width: 1024px) {
        .mega-menu {
            position: absolute;
            z-index: 50;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            max-width: 1100px;
            width: 100%;
            padding: 30px;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 30px;
            visibility: hidden;
            opacity: 0;
            transition: all 0.3s ease;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }
        .group:hover > .mega-menu {
            visibility: visible;
            opacity: 1;
        }
    }
    .megamenu-item ul { list-style: none; padding: 0; }
    .megamenu-item ul li a {
        font-size: 18px;
        color: #ffffff;
        padding: 15px 0;
        display: block;
        transition: all 0.3s ease;
        border-bottom: 1px solid #ffffff10;
    }
    .sub-menu,
    .megamenu-item ul li:last-child a {
        border-bottom: none;
    }
    .sub-menu li:last-child a {
        border-bottom: none;
    }
    .megamenu-item ul li a:hover { color: #C8815F; }

    /* ===== Wishlist & Cart Popups ===== */
    .wishlist_popup, .hdr_cart_popup { max-height: 450px; overflow-y: auto; }
    .wishlist_popup::-webkit-scrollbar,
    .hdr_cart_popup::-webkit-scrollbar { width: 4px; }
    .wishlist_popup::-webkit-scrollbar-thumb,
    .hdr_cart_popup::-webkit-scrollbar-thumb {
        background: #C8815F;
        border-radius: 10px;
    }
    .wishlist-item { max-height: 320px; overflow-y: auto; }
    .wishlist-item::-webkit-scrollbar { width: 4px; }
    .wishlist-item::-webkit-scrollbar-thumb { background: #C8815F; border-radius: 10px; }
    .hdr-cart-item { max-height: 320px; overflow-y: auto; }
    .hdr-cart-item::-webkit-scrollbar { width: 4px; }
    .hdr-cart-item::-webkit-scrollbar-thumb { background: #C8815F; border-radius: 10px; }

    /* ===== Buttons ===== */
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        text-align: center;
        cursor: pointer;
    }
    .btn-sm { padding: 10px 20px; font-size: 14px; }
    .btn-outline {
        border: 1px solid #111827;
        color: #111827;
        background: transparent;
    }
    .btn-outline:hover {
        background: #C8815F;
        border-color: #C8815F;
        color: #fff;
    }
    .btn-theme-solid {
        background: #C8815F;
        color: #fff;
        border: 1px solid #C8815F;
    }
    .btn-theme-solid:hover {
        background: #111827;
        border-color: #111827;
    }

    /* ===== Hamburger ===== */
    .hamburger {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        display: block;
    }
    @media (min-width: 1024px) {
        .hamburger { display: none; }
    }
    .hamburger svg { width: 35px; height: 35px; }
    .hamburger .line {
        fill: none;
        stroke: currentColor;
        stroke-width: 5;
        stroke-linecap: round;
        transition: stroke-dasharray 600ms cubic-bezier(0.4, 0, 0.2, 1),
                    stroke-dashoffset 600ms cubic-bezier(0.4, 0, 0.2, 1);
    }
    .hamburger .line1 { stroke-dasharray: 60 207; }
    .hamburger .line2 { stroke-dasharray: 60 60; }
    .hamburger .line3 { stroke-dasharray: 60 207; }
    .hamburger.active .line1 { stroke-dasharray: 90 207; stroke-dashoffset: -134; }
    .hamburger.active .line2 { stroke-dasharray: 1 60; stroke-dashoffset: -30; }
    .hamburger.active .line3 { stroke-dasharray: 90 207; stroke-dashoffset: -134; }

    /* ===== Dark/Light Switcher ===== */
    .switcher {
        display: flex;
        align-items: center;
        position: relative;
    }
    .switcher .sun { display: none; }
    .switcher .moon { display: block; }
    .switcher input:checked ~ .sun { display: block; }
    .switcher input:checked ~ .moon { display: none; }

    /* ===== Inc/Dec Buttons ===== */
    .inc-dec .dec, .inc-dec .inc { cursor: pointer; }

    /* ===== Search Button ===== */
    .hdr_search_btn, .hdr_wishList_btn, .hdr_cart_btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
    }

