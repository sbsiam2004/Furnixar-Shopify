<header class="header-area default-header relative z-50 bg-[#172430]" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
    <div class="container-fluid">
        <header class="flex items-center justify-between gap-x-6 max-w-[1720px] mx-auto relative">
            <!-- Logo -->
            <a href="{{ routes.root_url }}" style="flex-shrink: 0;">
                {% if section.settings.logo != blank %}
                    <img
                    src="{{ section.settings.logo | image_url: width: 280 }}"
                    alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
                    width="{{ section.settings.logo_width }}"
                    height="{{ section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio | round }}"
                    loading="eager"
                    style="width: {{ section.settings.logo_width }}px; height: auto;"
                    >
                {% elsif shop.brand.logo %}
                    <img
                    src="{{ shop.brand.logo | image_url: width: 280 }}"
                    alt="{{ shop.name | escape }}"
                    width="{{ section.settings.logo_width }}"
                    height="{{ section.settings.logo_width | divided_by: shop.brand.logo.aspect_ratio | round }}"
                    loading="eager"
                    style="width: {{ section.settings.logo_width }}px; height: auto;"
                    >
                {% else %}
                    <span>{{ shop.name }}</span>
                {% endif %}
            </a>

            <!-- Menu -->
            <div class="main-menu absolute z-50 w-full lg:w-auto top-full left-0 lg:static bg-white dark:bg-title lg:bg-transparent lg:dark:bg-transparent px-5 sm:px-7.5 py-2.5 sm:py-5 lg:px-0 lg:py-0">
                <ul class="text-lg leading-none text-title dark:text-white lg:flex lg:gap-7.5">
                    {% if section.settings.menu != blank %}
                        {% for link in section.settings.menu.links %}
                            {% if link.links != blank %}
                                {% assign is_mega_menu = false %}
                                {% for childlink in link.links %}
                                    {% if childlink.links != blank %}
                                        {% assign is_mega_menu = true %}
                                        {% break %}
                                    {% endif %}
                                {% endfor %}

                                <li class="group {% unless is_mega_menu %}relative{% endunless %}">
                                    <a href="{{ link.url }}" class="transition-all duration-300 hover:text-[#BB976D]">
                                            {{ link.title }}
                                        <span class="menu-list-toggle-icon text-lg! leading-none! font-medium!">
                                            <span class="plus-icon transition-all duration-300">+</span>
                                            <span class="minus-icon transition-all duration-300 text-[#BB976D]">−</span>
                                        </span>
                                    </a>
                                    
                                    {% if is_mega_menu %}
                                        <div class="mega-menu lg:absolute z-50 lg:top-full lg:left-1/2 lg:max-w-275 lg:w-full lg:bg-[#172430] lg:px-[30px] lg:py-[10px] lg:flex lg:items-start lg:justify-between lg:invisible lg:opacity-0 group-hover:lg:visible group-hover:lg:opacity-100 lg:transition-all lg:duration-300 lg:translateX(0)">
                                            <div class="lg:grid lg:items-start gap-x-5 lg:gap-x-7! lg:flex-1" style="grid-template-columns: repeat({{ link.links.size }}, minmax(0, 1fr));">
                                                {% for childlink in link.links %}
                                                    <div class="megamenu-item">
                                                        <ul>
                                                            {% if childlink.links != blank %}
                                                                {% for grandchildlink in childlink.links %}
                                                                    <li><a href="{{ grandchildlink.url }}">{{ grandchildlink.title }}</a></li>
                                                                {% endfor %}
                                                            {% else %}
                                                                <li><a href="{{ childlink.url }}">{{ childlink.title }}</a></li>
                                                            {% endif %}
                                                        </ul>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        </div>
                                    {% else %}
                                        <ul class="sub-menu lg:absolute z-50 lg:top-full lg:left-0 lg:min-w-55 lg:invisible lg:opacity-0 group-hover:lg:visible group-hover:lg:opacity-100 lg:transition-all lg:bg-[#172430] lg:px-[30px] flex flex-col px-[10px]">
                                            {% for childlink in link.links %}
                                                <li><a href="{{ childlink.url }}">{{ childlink.title }}</a></li>
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                </li>
                            {% else %}
                                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                            {% endif %}
                        {% endfor %}
                    {% else %}
                        <li><a href="{{ routes.root_url }}">Home</a></li>
                    {% endif %}
                    
                    {% if section.settings.enable_login_link %}
                        <li class="lg:hidden"><a href="{{ routes.account_url }}">{{ section.settings.login_text }}</a></li>
                    {% endif %}
                </ul>
            </div>

            <!-- Header Right -->
            <div class="flex items-center gap-4 sm:gap-6">
                {% if section.settings.enable_login_link %}
                <a href="{{ routes.account_url }}" class="text-lg leading-none text-title dark:text-white transition-all duration-300 hover:text-primary hidden lg:block">
                    {{ section.settings.login_text }}
                </a>
                {% endif %}
                
                {% if section.settings.enable_search %}
