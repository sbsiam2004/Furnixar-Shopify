{%- liquid
  assign section_icon = section_icon | default: category_icon
  assign section_title_class = section_title_class | default: 'leading-none mt-4 md:mt-6 text-2xl md:text-3xl font-semibold'
  assign section_description_class = section_description_class | default: 'mt-3'
  assign icon_color = icon_color | default: '#BB976D'
-%}

<div class="max-w-xl mx-auto mb-8 md:mb-12 text-center {{ wrapper_class }}">
  {% if show_section_icon %}
    <div class="flex justify-center icon-container {{ icon_container_class }}">
      {% if section_icon != blank %}
        <img
          class="mx-auto w-5 md:w-6 h-auto object-contain "
          src="{{ section_icon | image_url: width: 200 }}"
          alt="{{ section_title | escape }}"
          width="{{ section_icon.width }}"
          height="{{ section_icon.height }}"
          loading="lazy"
        >
      {% else %}
        <svg class="mx-auto w-6 h-6" viewBox="0 0 67 65" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12.756 51.3601C12.1769 55.3028 11.7832 59.3357 11.7832 63H17.2854C17.2854 63 18.1191 58.2701 19.528 52.2941" stroke="{{ icon_color }}" stroke-width="2.2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M54.2154 51.3601C54.7945 55.3028 55.1882 59.3357 55.1882 63H49.686C49.686 63 48.8523 58.2701 47.4434 52.2941" stroke="{{ icon_color }}" stroke-width="2.2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M60.6476 46.513C62.8649 40.3526 64.1991 33.2862 64.9036 28.7084C64.9492 28.4106 64.972 28.1129 64.972 27.8202C64.972 25.3672 63.4186 23.1334 61.0378 22.3174C57.8613 21.2277 54.4327 23.0485 53.5369 26.2858C53.0123 28.1813 52.5195 30.405 52.2483 32.7477C51.9176 35.6087 49.2682 37.6221 46.4249 37.1659C43.4448 36.687 39.2028 36.2689 33.4858 36.2689C27.7689 36.2689 23.5268 36.687 20.5467 37.1659C17.7035 37.6221 15.0541 35.6087 14.7234 32.7477C14.4522 30.405 13.9593 28.1813 13.4348 26.2858C12.7151 23.6871 10.3635 22.0006 7.82049 22.0006C7.19584 22.0006 6.55978 22.102 5.93385 22.3174C3.26798 23.2309 1.63983 25.9222 2.06809 28.7084C2.84099 33.7335 4.37412 41.7565 6.99817 48.2894C7.56201 49.6933 8.81259 50.7056 10.3039 50.9603C14.7297 51.7155 24.7014 53.2334 33.4858 53.2334C42.2703 53.2334 52.242 51.7155 56.6678 50.9603C57.5167 50.8159 58.2871 50.4243 58.8978 49.8567" stroke="{{ icon_color }}" stroke-width="2.2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M7.67188 22.0039C7.67314 19.2379 7.75677 16.472 7.92402 13.7047C8.08113 11.1212 9.02128 8.75057 10.5101 6.83352" stroke="{{ icon_color }}" stroke-width="2.2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M13.2656 4.23101C15.094 2.96902 17.2771 2.18979 19.6402 2.07449C28.8719 1.62342 38.1036 1.62342 47.3353 2.07449C53.6351 2.38238 58.6665 7.4113 59.0479 13.7047C59.2152 16.472 59.2988 19.2379 59.3001 22.0039" stroke="{{ icon_color }}" stroke-width="2.2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M14.6133 31.8984C16.3972 30.2599 20.5919 27.5935 29.3709 26.9441C30.6434 26.8501 32.0123 26.7987 33.4841 26.7987C45.1101 26.7987 50.3114 30.0217 52.3549 31.8984" stroke="{{ icon_color }}" stroke-width="2.2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      {% endif %}
    </div>
  {% endif %}

  {% if section_title != blank %}
    <h2 class="{{ section_title_class }}">
      {{ section_title }}
    </h2>
  {% endif %}

  {% if section_description != blank %}
    <p class="{{ section_description_class }}">
      {{ section_description }}
    </p>
  {% endif %}
</div>
