<div class="mt-5 md:mt-7 flex items-center gap-4 flex-wrap">
  <h4 class="text-xl md:text-[22px] font-semibold leading-none! text-white">Hurry Up!</h4>
  <div class="overflow-auto">
    <div
      class="py-2 px-3 bg-[#FAF2F2] rounded-[51px] flex items-end gap-[6px] w-[360px] max-w-full"
      data-countdown
      data-end-date="{{ sale_end_date | replace: ' ', 'T' }}"
    >
      <svg class="w-[15px] shrink-0" height="20" viewBox="0 0 15 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M12.6923 7.59087C12.6383 7.52329 12.573 7.53657 12.5387 7.55036C12.51 7.562 12.4442 7.59919 12.4533 7.69239C12.4642 7.80431 12.4704 7.91841 12.4715 8.03157C12.4764 8.50102 12.2881 8.96094 11.9549 9.2934C11.6218 9.62371 11.1884 9.80168 10.7247 9.79652C10.0913 9.78844 9.56601 9.45809 9.20551 8.84118C8.90742 8.33106 9.03844 7.67313 9.17715 6.97654C9.25832 6.5688 9.34227 6.14716 9.34227 5.74588C9.34227 2.62132 7.24173 0.818669 5.98962 0.0222265C5.96373 0.00578123 5.93908 0 5.91724 0C5.88173 0 5.85361 0.0153124 5.83974 0.0246874C5.81287 0.0428905 5.76986 0.0843747 5.78369 0.157812C6.26228 2.69929 4.83478 4.22783 3.32346 5.84611C1.76566 7.51419 0 9.40485 0 12.8147C0 16.7767 3.22331 20 7.18532 20C10.4475 20 13.3237 17.7256 14.1796 14.4692C14.7633 12.2487 14.1517 9.42031 12.6923 7.59087ZM7.36458 18.4663C6.37247 18.5115 5.42896 18.1557 4.7083 17.4667C3.99537 16.7849 3.58647 15.8336 3.58647 14.8565C3.58647 13.0228 4.28756 11.6768 6.17326 9.88973C6.20412 9.86047 6.23572 9.85121 6.26326 9.85121C6.28822 9.85121 6.30986 9.85883 6.32474 9.86598C6.35611 9.88109 6.40767 9.91852 6.40072 9.99945C6.33329 10.784 6.33447 11.4352 6.40415 11.9351C6.58228 13.2118 7.51692 14.0697 8.73 14.0697C9.32477 14.0697 9.89129 13.8458 10.3252 13.4394C10.3756 13.3922 10.4318 13.3982 10.4534 13.4028C10.4819 13.409 10.5202 13.4265 10.5402 13.4748C10.7202 13.9092 10.8121 14.3703 10.8135 14.8453C10.8193 16.7564 9.27207 18.3808 7.36458 18.4663Z" fill="#E13939"/>
      </svg>
      <h6 class="text-lg font-medium leading-none !text-[#E13939] whitespace-nowrap">Sale Ends :</h6>
      <div class="countdown-clock flex gap-[10px] items-center">
        <div class="countdown-item flex">
          <div class="ci-inner text-lg font-medium leading-none text-[#E13939]">
            <div class="clock-days ci-value" data-clock-days>00</div>
          </div>
          <p class="text-lg font-medium leading-none text-[#E13939]">D</p>
        </div>
        <p class="text-lg font-medium leading-none text-[#E13939]">:</p>
        <div class="countdown-item flex">
          <div class="ci-inner text-lg font-medium leading-none text-[#E13939]">
            <div class="clock-hours ci-value" data-clock-hours>00</div>
          </div>
          <p class="text-lg font-medium leading-none text-[#E13939]">H</p>
        </div>
        <p class="text-lg font-medium leading-none text-[#E13939]">:</p>
        <div class="countdown-item flex">
          <div class="ci-inner text-lg font-medium leading-none text-[#E13939]">
            <div class="clock-minutes ci-value" data-clock-minutes>00</div>
          </div>
          <p class="text-lg font-medium leading-none text-[#E13939]">M</p>
        </div>
        <p class="text-lg font-medium leading-none text-[#E13939]">:</p>
        <div class="countdown-item flex">
          <div class="ci-inner text-lg font-medium leading-none text-[#E13939]">
            <div class="clock-seconds ci-value" data-clock-seconds>00</div>
          </div>
          <p class="text-lg font-medium leading-none text-[#E13939]">S</p>
        </div>
      </div>
    </div>
  </div>
</div>
