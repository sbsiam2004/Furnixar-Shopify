{%- liquid
  assign tabs_id = 'product-details-tabs-' | append: section_id

  if section.settings.use_product_description and product.description != blank
    assign description_body = product.description
  elsif section.settings.description_text != blank
    assign description_body = section.settings.description_text
  else
    assign description_body = 'Crafted with plush cushioning and ergonomic design, it offers unparalleled comfort for lounging or reading. Its timeless style seamlessly blends with any decor, while the sturdy construction ensures durability for years to come. Whether you are unwinding after a long day or enjoying a leisurely weekend, this chair provides the perfect retreat.'
  endif

  assign detail_leather = section.settings.detail_leather | default: 'From Japan'
  assign detail_brand = section.settings.detail_brand | default: product.vendor | default: 'Navana'
  assign detail_weight = section.settings.detail_weight | default: '1kg'
  assign detail_color = section.settings.detail_color

  if detail_color == blank
    for option in product.options_with_values
      assign option_name_downcase = option.name | downcase
      if option_name_downcase == 'color' or option_name_downcase == 'colour'
        assign detail_color = option.values | join: ' , '
        break
      endif
    endfor
  endif

  if detail_color == blank
    assign detail_color = 'Wooden , White , Blue , Orange'
  endif

  assign review_blocks = section.blocks | where: 'type', 'review'
-%}

<!-- Description Start -->
<div
  class="product-details-tabs text-white"
  data-product-details-tabs
  id="{{ tabs_id }}"
  style="
    padding-top: {{ section.settings.tabs_padding_top }}px;
    padding-bottom: {{ section.settings.tabs_padding_bottom }}px;
  "
>
  <div class="max-w-[985px] mx-auto">
    <div class="product-dtls-navtab border-y border-white/15">
      <ul
        id="user-nav-tabs"
        class="sm:max-w-[70%] text-white text-base sm:text-lg lg:text-xl flex leading-none gap-3 sm:gap-6 md:gap-12 lg:gap-24 justify-between sm:justify-start max-w-full"
        role="tablist"
      >
        <li role="presentation" class="py-3 sm:py-5 lg:py-6 relative before:absolute before:w-full before:h-px before:bg-primary before:top-full before:left-0 before:duration-300 before:opacity-0 active" data-tab-item>
          <a class="duration-300 hover:text-primary text-white" href="#content1" data-tab-link>{{ section.settings.tab_description_label | default: 'Description' }}</a>
        </li>
        <li role="presentation" class="py-3 sm:py-5 lg:py-6 relative before:absolute before:w-full before:h-px before:bg-primary before:top-full before:left-0 before:duration-300 before:opacity-0" data-tab-item>
          <a class="duration-300 hover:text-primary text-white" href="#content2" data-tab-link>{{ section.settings.tab_vendor_label | default: 'Vendor Info' }}</a>
        </li>
        <li role="presentation" class="py-3 sm:py-5 lg:py-6 relative before:absolute before:w-full before:h-px before:bg-primary before:top-full before:left-0 before:duration-300 before:opacity-0" data-tab-item>
          <a class="duration-300 hover:text-primary text-white" href="#content3" data-tab-link>{{ section.settings.tab_review_label | default: 'Review' }}</a>
        </li>
        <li role="presentation" class="py-3 sm:py-5 lg:py-6 relative before:absolute before:w-full before:h-px before:bg-primary before:top-full before:left-0 before:duration-300 before:opacity-0" data-tab-item>
          <a class="duration-300 hover:text-primary text-white" href="#content4" data-tab-link>{{ section.settings.tab_shipping_label | default: 'Shipping' }}</a>
        </li>
      </ul>
    </div>
    <div id="content" class="mt-5 sm:mt-8 lg:mt-12 mx-0 sm:mr-5 md:mr-8 lg:mr-12" data-tab-panels>
      <div id="content1" class="text-white/90" data-tab-panel>
        <div class="sm:text-lg rte product-tab-description">{{ description_body }}</div>
        <ul class="mt-4 sm:mt-6 grid gap-4 sm:gap-5 sm:text-lg leading-none text-white">
          {% if detail_leather != blank %}
            <li>Leather : {{ detail_leather }}</li>
          {% endif %}
          {% if detail_brand != blank %}
            <li>Brand : {{ detail_brand }}</li>
          {% endif %}
          {% if detail_weight != blank %}
            <li>Weight : {{ detail_weight }}</li>
          {% endif %}
          {% if detail_color != blank %}
            <li>Color : {{ detail_color }}</li>
          {% endif %}
        </ul>
      </div>
      <div id="content2" class="hidden text-white/90" data-tab-panel hidden>
        <div class="max-w-[680px] flex items-start justify-between gap-y-8 gap-x-10 flex-wrap">
          <div>
            <span class="text-primary sm:text-lg leading-none block">{{ section.settings.vendor_1_label | default: 'Shop Name' }}</span>
            <h4 class="font-semibold mt-2 sm:mt-3 text-xl sm:text-2xl leading-none text-white">{{ section.settings.vendor_1_shop | default: 'John Furniture House' }}</h4>
            <ul class="mt-4 sm:mt-6 grid gap-3 sm:text-lg text-white/90">
              {% if section.settings.vendor_1_name != blank %}
                <li>Vendor : {{ section.settings.vendor_1_name }}</li>
              {% endif %}
              {% if section.settings.vendor_1_address != blank %}
                <li>Shop : {{ section.settings.vendor_1_address }}</li>
              {% endif %}
              {% if section.settings.vendor_1_email != blank %}
                <li>Mail : {{ section.settings.vendor_1_email }}</li>
              {% endif %}
              {% if section.settings.vendor_1_phone != blank %}
                <li>Call : {{ section.settings.vendor_1_phone }}</li>
              {% endif %}
            </ul>
          </div>
          <div>
            <span class="text-primary sm:text-lg leading-none block">{{ section.settings.vendor_2_label | default: 'Shop Name' }}</span>
            <h4 class="font-semibold mt-2 sm:mt-3 text-xl sm:text-2xl leading-none text-white">{{ section.settings.vendor_2_shop | default: 'Furniture Gallery' }}</h4>
            <ul class="mt-4 sm:mt-6 grid gap-3 sm:text-lg text-white/90">
              {% if section.settings.vendor_2_name != blank %}
                <li>Vendor : {{ section.settings.vendor_2_name }}</li>
              {% endif %}
              {% if section.settings.vendor_2_address != blank %}
                <li>Shop : {{ section.settings.vendor_2_address }}</li>
              {% endif %}
              {% if section.settings.vendor_2_email != blank %}
                <li>Mail : {{ section.settings.vendor_2_email }}</li>
              {% endif %}
              {% if section.settings.vendor_2_phone != blank %}
                <li>Call : {{ section.settings.vendor_2_phone }}</li>
              {% endif %}
            </ul>
          </div>
        </div>
      </div>
      <div id="content3" class="hidden text-white/90" data-tab-panel hidden>
        <div class="max-w-[905px] flex items-start xl:justify-between gap-8 flex-wrap">
          {% if review_blocks.size > 0 %}
            {% for block in review_blocks %}
              <div class="sm:max-w-[260px] w-full" {{ block.shopify_attributes }}>
                <svg class="fill-current text-white" width="60" height="51" viewBox="0 0 60 51" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M0 25.5539C0 20.8097 0.974729 16.5328 2.92419 12.723C4.94585 8.91332 7.87004 5.89429 11.6968 3.66596C15.5235 1.36575 20.1083 0.143763 25.4513 0V11.2135C20.9025 11.2135 17.509 12.4715 15.2708 14.9873C13.1047 17.5032 12.0217 21.0254 12.0217 25.5539V28.1416H24.3682V51H0V25.5539ZM60 11.2135C55.4513 11.2135 52.0578 12.4715 49.8195 14.9873C47.6534 17.5032 46.5704 21.0254 46.5704 25.5539V28.1416H58.917V51H34.5487V25.5539C34.5487 20.8097 35.5235 16.5328 37.4729 12.723C39.4946 8.91332 42.4188 5.89429 46.2455 3.66596C50.0722 1.36575 54.657 0.143763 60 0V11.2135Z"/>
                </svg>
                <ul class="flex items-center gap-2 mt-4 sm:mt-6" aria-label="Rating">
                  {% assign rating = block.settings.rating | default: 4 %}
                  {% for i in (1..5) %}
                    <li>
                      <svg width="15" height="14" viewBox="0 0 15 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        {% if i <= rating %}
                          <path d="M11.1622 13.6923L7.181 11.201L3.19978 13.6922C3.05515 13.7839 2.86858 13.7769 2.72931 13.6758C2.59043 13.5751 2.52673 13.4001 2.56864 13.2337L3.70764 8.67717L0.150459 5.6612C0.0189569 5.55107 -0.0324041 5.37191 0.0206119 5.2088C0.0736279 5.04526 0.220726 4.93062 0.391668 4.9187L5.03447 4.59449L6.79065 0.23853C6.91968 -0.07951 7.44233 -0.07951 7.57136 0.23853L9.32754 4.59449L13.9703 4.9187C14.1413 4.93062 14.2884 5.04526 14.3414 5.2088C14.3944 5.37191 14.3431 5.55107 14.2115 5.6612L10.6543 8.67723L11.7933 13.2337C11.8353 13.4001 11.7716 13.5752 11.6327 13.6759C11.4905 13.7791 11.3045 13.7814 11.1622 13.6923Z" fill="#EE9818"/>
                        {% else %}
                          <path class="fill-white/30" d="M11.6075 13.6923L7.62632 11.201L3.64509 13.6922C3.50046 13.7839 3.3139 13.7769 3.17462 13.6758C3.03574 13.5751 2.97204 13.4001 3.01395 13.2337L4.15295 8.67717L0.595772 5.6612C0.464269 5.55107 0.412908 5.37191 0.465924 5.2088C0.51894 5.04526 0.666039 4.93062 0.836981 4.9187L5.47978 4.59449L7.23596 0.23853C7.365 -0.07951 7.88764 -0.07951 8.01667 0.23853L9.77285 4.59449L14.4157 4.9187C14.5866 4.93062 14.7337 5.04526 14.7867 5.2088C14.8397 5.37191 14.7884 5.55107 14.6569 5.6612L11.0997 8.67723L12.2387 13.2337C12.2806 13.4001 12.2169 13.5752 12.078 13.6759C11.9358 13.7791 11.7498 13.7814 11.6075 13.6923Z" fill-opacity="0.3"/>
                        {% endif %}
                      </svg>
                    </li>
                  {% endfor %}
                  {% if block.settings.review_count != blank %}
                    <li class="text-white/80">( {{ block.settings.review_count }} )</li>
                  {% endif %}
                </ul>
                {% if block.settings.author != blank %}
                  <h6 class="font-semibold! leading-none mt-[10px] text-white">{{ block.settings.author }}</h6>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p class="sm:text-lg mt-3 text-white/90">{{ block.settings.text }}</p>
                {% endif %}
              </div>
            {% endfor %}
          {% else %}
            {% for i in (1..3) %}
              <div class="sm:max-w-[260px] w-full">
                <svg class="fill-current text-white" width="60" height="51" viewBox="0 0 60 51" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M0 25.5539C0 20.8097 0.974729 16.5328 2.92419 12.723C4.94585 8.91332 7.87004 5.89429 11.6968 3.66596C15.5235 1.36575 20.1083 0.143763 25.4513 0V11.2135C20.9025 11.2135 17.509 12.4715 15.2708 14.9873C13.1047 17.5032 12.0217 21.0254 12.0217 25.5539V28.1416H24.3682V51H0V25.5539ZM60 11.2135C55.4513 11.2135 52.0578 12.4715 49.8195 14.9873C47.6534 17.5032 46.5704 21.0254 46.5704 25.5539V28.1416H58.917V51H34.5487V25.5539C34.5487 20.8097 35.5235 16.5328 37.4729 12.723C39.4946 8.91332 42.4188 5.89429 46.2455 3.66596C50.0722 1.36575 54.657 0.143763 60 0V11.2135Z"/>
                </svg>
                <ul class="flex items-center gap-2 mt-4 sm:mt-6">
                  {% for star in (1..4) %}
                    <li>
                      <svg width="15" height="14" viewBox="0 0 15 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M11.1622 13.6923L7.181 11.201L3.19978 13.6922C3.05515 13.7839 2.86858 13.7769 2.72931 13.6758C2.59043 13.5751 2.52673 13.4001 2.56864 13.2337L3.70764 8.67717L0.150459 5.6612C0.0189569 5.55107 -0.0324041 5.37191 0.0206119 5.2088C0.0736279 5.04526 0.220726 4.93062 0.391668 4.9187L5.03447 4.59449L6.79065 0.23853C6.91968 -0.07951 7.44233 -0.07951 7.57136 0.23853L9.32754 4.59449L13.9703 4.9187C14.1413 4.93062 14.2884 5.04526 14.3414 5.2088C14.3944 5.37191 14.3431 5.55107 14.2115 5.6612L10.6543 8.67723L11.7933 13.2337C11.8353 13.4001 11.7716 13.5752 11.6327 13.6759C11.4905 13.7791 11.3045 13.7814 11.1622 13.6923Z" fill="#EE9818"/>
                      </svg>
                    </li>
                  {% endfor %}
                  <li>
                    <svg class="fill-white/30" width="15" height="14" viewBox="0 0 15 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M11.6075 13.6923L7.62632 11.201L3.64509 13.6922C3.50046 13.7839 3.3139 13.7769 3.17462 13.6758C3.03574 13.5751 2.97204 13.4001 3.01395 13.2337L4.15295 8.67717L0.595772 5.6612C0.464269 5.55107 0.412908 5.37191 0.465924 5.2088C0.51894 5.04526 0.666039 4.93062 0.836981 4.9187L5.47978 4.59449L7.23596 0.23853C7.365 -0.07951 7.88764 -0.07951 8.01667 0.23853L9.77285 4.59449L14.4157 4.9187C14.5866 4.93062 14.7337 5.04526 14.7867 5.2088C14.8397 5.37191 14.7884 5.55107 14.6569 5.6612L11.0997 8.67723L12.2387 13.2337C12.2806 13.4001 12.2169 13.5752 12.078 13.6759C11.9358 13.7791 11.7498 13.7814 11.6075 13.6923Z"/>
                    </svg>
                  </li>
                  <li class="text-white/80">( 125 )</li>
                </ul>
                <h6 class="font-semibold leading-none mt-[10px] text-white">Merlina Quexy</h6>
                <p class="sm:text-lg mt-3 text-white/90">Furnixar's products have transformed my living space with their stylish designs and impeccable craftsmanship.</p>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>
      <div id="content4" class="hidden text-white/90" data-tab-panel hidden>
        <div>
          <h4 class="text-xl sm:text-2xl leading-none font-medium text-white">{{ section.settings.shipping_title_1 | default: 'For Shipping' }}</h4>
          <p class="sm:text-lg mt-3">{{ section.settings.shipping_text_1 | default: 'Shipping times may vary based on your location and the selected delivery option. Please review our shipping policies for details on processing times, charges, and tracking updates. Contact us for any shipping-related inquiries or assistance.' }}</p>
        </div>
        <div class="mt-5 sm:mt-6">
          <h4 class="text-xl sm:text-2xl leading-none font-medium text-white">{{ section.settings.shipping_title_2 | default: 'Item Return' }}</h4>
          <p class="sm:text-lg mt-3">{{ section.settings.shipping_text_2 | default: 'We offer a hassle-free process to ensure your satisfaction. Please review our return policy for eligibility and steps to initiate a return.' }}</p>
        </div>
        <div class="mt-5 sm:mt-6">
          <h4 class="text-xl sm:text-2xl leading-none font-medium text-white">{{ section.settings.shipping_title_3 | default: 'Accepted Problem Issue' }}</h4>
          <p class="sm:text-lg mt-3">{{ section.settings.shipping_text_3 | default: 'Choose from multiple methods, including credit cards, debit cards, and online payment gateways. All transactions are encrypted to ensure your information remains safe. For any payment-related concerns, our support team is here to assist.' }}</p>
        </div>
      </div>
    </div>
  </div>
</div>
<!-- Description End -->
