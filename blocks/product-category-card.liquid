{% render 'product-category-card', block: block %}

{% schema %}
{
  "name": "Category card",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (optional override)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title (optional override)"
    },
    {
      "type": "text",
      "id": "item_count",
      "label": "Item count (optional override)"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional override)"
    }
  ]
}
{% endschema %}
